# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/pms_db"

# JWT
JWT_SECRET="your-jwt-secret-key"
JWT_ACCESS_SECRET="your-jwt-access-secret-key"
